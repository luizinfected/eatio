{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/eatio-service/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/eatio-service/tsconfig.app.json",
    "webpackConfigPath": "webpack.config.js"
  },
  "monorepo": true,
  "root": "apps/eatio-service",
  "projects": {
    "bff": {
      "type": "application",
      "root": "apps/bff",
      "entryFile": "main",
      "sourceRoot": "apps/bff/src",
      "compilerOptions": {
        "tsConfigPath": "apps/bff/tsconfig.app.json"
      }
    },
    "eatio-service": {
      "type": "application",
      "root": "apps/eatio-service",
      "entryFile": "main",
      "sourceRoot": "apps/eatio-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/eatio-service/tsconfig.app.json"
      }
    }
  }
}